# =============================================================================
# VerbaFlow AI - Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=VerbaFlow AI
APP_VERSION=1.0.0
APP_ENV=production
# Enable debug mode (set to false in production)
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Full async DSN used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://verbaflow:change_me_in_production@postgres:5432/verbaflow
# Individual vars used by postgres Docker image
POSTGRES_DB=verbaflow
POSTGRES_USER=verbaflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
# Cache TTL in seconds (default 1 hour)
REDIS_CACHE_TTL=3600
# Celery broker/backend (if using background tasks)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
# MUST be at least 32 random characters — generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# Password hashing cost factor
BCRYPT_ROUNDS=12

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here


# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=models/gemini-2.5-flash
GEMINI_PRO_VISION_MODEL=gemini-1.5-pro-vision
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# OpenAI (fallback / alternative)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# Active provider selection
EMBEDDING_PROVIDER=google
LLM_PROVIDER=gemini

# Embedding models
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=768

# -----------------------------------------------------------------------------
# Vector Store
# -----------------------------------------------------------------------------
# Options: faiss | pinecone | weaviate | qdrant
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./data/faiss_indexes

# Pinecone (if VECTOR_STORE_TYPE=pinecone)
PINECONE_API_KEY=
PINECONE_ENV=us-east-1-aws
PINECONE_INDEX=verbaflow

# Weaviate (if VECTOR_STORE_TYPE=weaviate)
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=

# Qdrant (if VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
# Local storage path (used in development / single-node)
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,md,csv,xlsx,pptx,html

# AWS S3 (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=verbaflow-uploads

# Google Cloud Storage (alternative)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# Storage backend: local | s3 | gcs
STORAGE_BACKEND=local

# -----------------------------------------------------------------------------
# RAG Pipeline Settings
# -----------------------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_COUNT=5
SIMILARITY_THRESHOLD=0.7
RERANKING_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MAX_CONTEXT_LENGTH=12000
CITATION_ENABLED=true

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
ALLOW_CREDENTIALS=true
ALLOWED_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
ALLOWED_HEADERS=["*"]

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# These NEXT_PUBLIC_* vars are embedded at build time
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=VerbaFlow AI
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SENTRY_DSN=
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=verbaflow-backend
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Email (for notifications / password reset)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=VerbaFlow AI

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# pgAdmin (optional — dev only)
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@verbaflow.local
PGADMIN_DEFAULT_PASSWORD=admin_change_me
