# =============================================================================
# VerbaFlow AI — Docker-specific Environment Variables
# =============================================================================
# Used exclusively within docker-compose context.
# Copy to docker/.env (or root .env) before running `docker compose up`.
# =============================================================================

# -----------------------------------------------------------------------------
# Compose Project
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=verbaflow

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=verbaflow
POSTGRES_USER=verbaflow
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://verbaflow:change_me_in_production@postgres:5432/verbaflow
REDIS_URL=redis://redis:6379/0
SECRET_KEY=docker-dev-secret-key-change-in-production-min32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=false
LOG_LEVEL=INFO
APP_ENV=development

# AI
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
EMBEDDING_PROVIDER=google
LLM_PROVIDER=gemini
GEMINI_MODEL=models/gemini-2.5-flash
OPENAI_MODEL=gpt-4o
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Vector Store
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=/app/data/faiss_indexes

# Storage
UPLOAD_DIR=/app/data/uploads
MAX_FILE_SIZE_MB=50
STORAGE_BACKEND=local

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_COUNT=5
SIMILARITY_THRESHOLD=0.7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://frontend:3000"]

# Monitoring
PROMETHEUS_ENABLED=true

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=VerbaFlow AI
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# pgAdmin (dev only — uncomment service in docker-compose.yml)
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@verbaflow.local
PGADMIN_DEFAULT_PASSWORD=admin_change_me
PGADMIN_LISTEN_PORT=5050
